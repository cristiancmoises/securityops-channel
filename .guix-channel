;; -*- mode: scheme; -*-
;;; SPDX-License-Identifier: GPL-3.0-or-later
;;
;; securityops — a personal GNU Guix channel that pins the latest upstream
;; versions of the securityops workstation's most-used applications
;; (alacritty, kitty, tor, torbrowser, fish, emacs, mpv, vlc, openshot,
;; keepassxc, ueberzugpp, lf, librewolf, ungoogled-chromium, google-chrome,
;; mullvad-vpn-desktop, steam, glances).
;;
;; Depends on nonguix for google-chrome, steam, and Mullvad's
;; `chromium-binary-build-system'.  (You already have nonguix in channels.scm,
;; pinned at bf39542 — well after the introduction commit below, so no
;; conflict.)
;;
(channel
 (version 0)
 (news-file "etc/news.txt")
 ;; Official home: git.securityops.co, cloned/pulled over HTTPS with no account.
 ;; Public mirrors are Codeberg and GitHub (see README.md → "Install").
 ;; Commits are GPG-signed; add the `(introduction ...)' from the README to
 ;; channels.scm to verify signatures on pull (keys in .guix-authorizations).
 (url "https://git.securityops.co/cristiancmoises/securityops-channel")
 (dependencies
  (channel
   (name nonguix)
   (url "https://github.com/nonguix/nonguix")
   (introduction
    (channel-introduction
     (version 0)
     (commit "897c1a470da759236cc11798f4e0a5f7d4d59fbc")
     (signer "2A39 3FFF 68F4 EF7A 3D29  12AF 6F51 20A0 22FB B2D5"))))))
